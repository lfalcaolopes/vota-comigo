# Base URL of the back-end API consumed by the web app.
# Falls back to http://localhost:3001 when unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Public URL of the deployed site. Used for metadataBase, OpenGraph, robots and sitemap.
# Required in production; falls back to http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

