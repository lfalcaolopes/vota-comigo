PORT=3001
DATABASE_URL=postgresql://vota_comigo:vota_comigo@localhost:5432/vota_comigo
# Allowed CORS origin(s), comma-separated. Required in production (the real web
# domain); otherwise the browser is blocked. Defaults to http://localhost:3000.
WEB_ORIGIN=http://localhost:3000
# Only used by the resumo-IA ingestion CLIs, not the HTTP server.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
